<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4EDED"
    android:orientation="vertical"
    tools:context=".Attendance.StudentAttTrdYear">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/attTrdStudentToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/purple">
        <ImageButton
            android:id="@+id/attTrdStudentToolbar_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/transparent"
            android:src="@drawable/baseline_arrow_back_24"
            tools:ignore="ContentDescription" />
        <TextView
            android:id="@+id/attTrdStudentToolbar_textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SECOND YEAR SUBJECT"
            android:textColor="@color/white"
            android:textAllCaps="true"
            android:textSize="22sp"
            tools:ignore="HardcodedText" />
    </androidx.appcompat.widget.Toolbar>

    <CalendarView
        android:id="@+id/calendarAttTrd"
        android:layout_width="match_parent"
        android:background="#000"
        android:layout_height="wrap_content"
        tools:ignore="InvalidId" />
    <View
        android:layout_width="match_parent"
        android:layout_height="2sp"
        android:background="#FFFDFD"
        tools:ignore="SmallSp" />
    <RelativeLayout
        android:layout_width="match_parent"
        android:background="#2CC1B2"
        android:padding="7sp"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roll No."
            android:textStyle="bold"
            android:fontFamily="sans-serif-smallcaps"
            android:textColor="@color/black"
            android:textSize="23sp"
            tools:ignore="HardcodedText" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textStyle="bold"
            android:fontFamily="sans-serif-smallcaps"
            android:layout_centerInParent="true"
            android:textColor="@color/black"
            android:textSize="23sp"
            tools:ignore="HardcodedText" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Attendance"
            android:textStyle="bold"
            android:fontFamily="sans-serif-smallcaps"
            android:layout_alignParentEnd="true"
            android:textColor="@color/black"
            android:textSize="23sp"
            tools:ignore="HardcodedText" />

    </RelativeLayout>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/studentRecyclerAttTrd"
                android:background="#D6ECE9"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/attTrdPBStudent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center" />

</LinearLayout>