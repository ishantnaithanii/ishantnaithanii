<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4EDED"
    android:orientation="vertical"
    tools:context=".Attendance.AttSndYear">
    <include
        android:id="@+id/toolbarStudent"
        layout="@layout/toolbar"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="2sp"
        android:background="#FFFDFD"
        tools:ignore="SmallSp" />
    <RelativeLayout
        android:layout_width="match_parent"
        android:background="#2CC1B2"
        android:padding="7sp"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roll No."
            android:textStyle="bold"
            android:fontFamily="sans-serif-smallcaps"
            android:textColor="@color/black"
            android:textSize="23sp"
            tools:ignore="HardcodedText" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textStyle="bold"
            android:fontFamily="sans-serif-smallcaps"
            android:layout_centerInParent="true"
            android:textColor="@color/black"
            android:textSize="23sp"
            tools:ignore="HardcodedText" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Attendance"
            android:textStyle="bold"
            android:fontFamily="sans-serif-smallcaps"
            android:layout_alignParentEnd="true"
            android:textColor="@color/black"
            android:textSize="23sp"
            tools:ignore="HardcodedText" />

    </RelativeLayout>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerAttSnd"
                android:background="#D6ECE9"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <Button
                android:id="@+id/AttSndSubmitBtn"
                android:layout_width="170sp"
                android:layout_height="60sp"
                android:text="Submit"
                android:textSize="29sp"
                android:layout_marginTop="10sp"
                android:fontFamily="sans-serif-smallcaps"
                android:layout_gravity="center"
                android:backgroundTint="#A89B59"
                tools:ignore="HardcodedText,UnusedAttribute" />
        </LinearLayout>

    </ScrollView>

</LinearLayout>