<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBF8F8"
    android:orientation="vertical"
    tools:context=".Upload_TimeTable">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/timetableToolBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/purple"
        android:layout_marginBottom="20sp">
        <ImageButton
            android:id="@+id/timetableToolbarib"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/transparent"
            android:src="@drawable/baseline_arrow_back_24"
            tools:ignore="ContentDescription" />
        <TextView
            android:id="@+id/timetableToolbartv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UPLOAD TIMETABLE"
            android:textColor="@color/white"
            android:textSize="25sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />
    </androidx.appcompat.widget.Toolbar>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="18sp"
        android:backgroundTint="@color/white"
        android:layout_marginStart="15sp"
        android:layout_marginEnd="15sp"
        app:cardElevation="12sp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            tools:ignore="UselessLeaf">
            <androidx.cardview.widget.CardView
                android:id="@+id/timeTableImage"
                android:layout_width="200dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:layout_marginTop="15sp"
                app:cardCornerRadius="8sp"
                android:layout_margin="10dp"
                android:layout_weight="1"
                tools:ignore="InefficientWeight">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#48E3CE"
                    android:gravity="center"
                    android:orientation="vertical"
                    tools:ignore="UseCompoundDrawables">

                    <ImageView
                        android:layout_width="81dp"
                        android:layout_height="85dp"
                        app:srcCompat="@drawable/addimage"
                        tools:ignore="ContentDescription" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-smallcaps"
                        android:text="Select Timetable"
                        android:textColor="@color/black"
                        android:textSize="24sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/uploadTimetableBtn"
                android:layout_width="230dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10sp"
                android:background="@drawable/shape4"
                android:fontFamily="sans-serif-smallcaps"
                android:text="Upload Timetable"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_marginTop="10sp"
                android:background="#F4F4F4"
                app:cardCornerRadius="8sp"
                android:layout_marginLeft="8sp"
                android:layout_marginRight="8sp"
                android:layout_marginBottom="10sp"
                android:layout_height="400dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#F4F4F4"
                    android:id="@+id/timetableImageView"
                    tools:ignore="ContentDescription" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>