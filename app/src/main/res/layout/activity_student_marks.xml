<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:background="#F6F3F3"
    android:layout_height="match_parent"
    tools:context=".Marks.StudentMarksActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/studentMarksToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2CC1B2">
        <ImageButton
            android:id="@+id/studentMarksToolbar_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/transparent"
            android:src="@drawable/baseline_arrow_back_24"
            tools:ignore="ContentDescription" />
        <TextView
            android:id="@+id/studentMarksToolbar_textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SECOND YEAR SUBJECT"
            android:textColor="@color/white"
            android:textSize="25sp"
            tools:ignore="HardcodedText" />

    </androidx.appcompat.widget.Toolbar>
    <View
        android:layout_width="match_parent"
        android:layout_height="2sp"
        android:background="#FFFDFD"
        tools:ignore="SmallSp" />
    <RelativeLayout
        android:layout_width="match_parent"
        android:background="#2CC1B2"
        android:padding="7sp"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roll No."
            android:textStyle="bold"
            android:fontFamily="sans-serif-smallcaps"
            android:textColor="@color/black"
            android:textSize="23sp"
            tools:ignore="HardcodedText" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textStyle="bold"
            android:fontFamily="sans-serif-smallcaps"
            android:layout_centerInParent="true"
            android:textColor="@color/black"
            android:textSize="23sp"
            tools:ignore="HardcodedText" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Marks"
            android:textStyle="bold"
            android:fontFamily="sans-serif-smallcaps"
            android:layout_alignParentEnd="true"
            android:textColor="@color/black"
            android:textSize="23sp"
            tools:ignore="HardcodedText" />


    </RelativeLayout>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMarks2"
            android:background="#FBFAFA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
            <Button
                android:id="@+id/marks2SubmitBtn"
                android:layout_width="170sp"
                android:layout_height="60sp"
                android:text="Submit"
                android:textSize="29sp"
                android:layout_marginTop="10sp"
                android:fontFamily="sans-serif-smallcaps"
                android:layout_gravity="center"
                android:backgroundTint="#A89B59"
                tools:ignore="HardcodedText,UnusedAttribute" />
        </LinearLayout>

    </ScrollView>
    </LinearLayout>