<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/loginback2"
    android:orientation="vertical"
    android:gravity="center"
    tools:context=".Login_and_Register.Login">

    <androidx.cardview.widget.CardView
        android:layout_width="350dp"
        android:layout_height="470dp"
        app:cardElevation="18sp"
        android:backgroundTint="@color/white"
        android:layout_gravity="center"
        android:layout_marginTop="300dp"
        app:cardCornerRadius="20sp"
        tools:ignore="UnusedAttribute">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Login Here"
        android:textSize="40sp"
        android:textColor="@color/purple"
        android:textStyle="bold"
        android:fontFamily="sans-serif-smallcaps"
        tools:ignore="HardcodedText" />
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/loginProfile"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="70dp"
        android:visibility="gone"
        android:src="@drawable/login_profile" />

    <EditText
        android:id="@+id/login_email"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="20sp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:padding="8sp"
        android:layout_marginBottom="10sp"
        android:background="@drawable/border2"
        android:ems="10"
        android:fontFamily="@font/amiko"
        android:hint="Email"
        android:textSize="20sp"
        android:importantForAutofill="no"
        android:inputType="textEmailAddress"
        android:textColor="#000"
        tools:ignore="HardcodedText,LabelFor,TextFields" />

    <LinearLayout
        android:id="@+id/loginPwdLinear"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="10sp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:gravity="center"
        android:background="@drawable/border2"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/login_password"
            android:layout_width="290dp"
            android:layout_height="40dp"
            android:ems="10"
            android:textSize="20sp"
            android:layout_marginStart="10sp"
            android:fontFamily="@font/amiko"
            android:background="@color/white"
            android:hint="Password"
            android:importantForAutofill="no"
            android:inputType="textPassword"
            android:textColor="#000"
            tools:ignore="HardcodedText,LabelFor,TextFields" />


        <ImageView
            android:id="@+id/login_show_hide_pwd"
            android:layout_width="30dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:layout_marginEnd="5sp"
            android:src="@drawable/hide_pwd"
            tools:ignore="ContentDescription" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50sp"
        android:layout_marginTop="10sp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/border2"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/clg_password"
            android:layout_width="290dp"
            android:layout_height="48dp"
            android:ems="10"
            android:textSize="20sp"
            android:fontFamily="@font/amiko"
            android:hint="Your College Id"
            android:padding="8sp"
            android:importantForAutofill="no"
            android:inputType="textPassword"
            android:textColor="#000"
            tools:ignore="HardcodedText,LabelFor,TextFields" />


        <ImageView
            android:id="@+id/clg_show_hide_pwd"
            android:layout_width="30dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:layout_marginEnd="5sp"
            android:src="@drawable/hide_pwd"
            tools:ignore="ContentDescription" />
    </LinearLayout>
    <ProgressBar
        android:id="@+id/login_progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10sp"
        android:visibility="invisible"
        android:layout_gravity="center"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/login_loginBtn"
        android:layout_width="150dp"
        android:layout_height="35dp"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10sp"
        android:background="@drawable/shape1"
        android:fontFamily="sans-serif-smallcaps"
        android:text="Login"
        android:textSize="29sp"
        tools:ignore="HardcodedText" />
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/login_forgotPwdBtn"
        android:layout_width="224dp"
        android:layout_height="42dp"
        android:layout_gravity="center"
        android:layout_marginTop="10sp"
        android:background="#2DDADA"
        android:fontFamily="sans-serif-smallcaps"
        android:text="Forgot Password"
        android:textSize="22sp"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/login_register"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif-smallcaps"
        android:text="Already Login? Register Here"
        android:textColor="#FF0505"
        android:textSize="20sp"
        android:layout_marginBottom="10sp"
        tools:ignore="HardcodedText" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>


</LinearLayout>