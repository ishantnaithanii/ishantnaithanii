<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="9sp"
    android:layout_margin="6dp"
    android:layout_height="wrap_content">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:background="#D6ECE9"
        android:padding="7sp">

        <TextView
            android:id="@+id/studentRollNoReport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:fontFamily="sans-serif-smallcaps"
            android:text="Roll No."
            android:layout_marginTop="4sp"
            android:textColor="@color/black"
            android:textSize="21sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/studentNameReport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="4sp"
            android:fontFamily="sans-serif-smallcaps"
            android:text="Name"
            android:textColor="@color/black"
            android:textSize="21sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/studentMarksReport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:fontFamily="sans-serif-smallcaps"
            android:text="Marks"
            android:layout_marginTop="4sp"
            android:layout_marginEnd="10sp"
            android:textColor="@color/black"
            android:textColorHint="#3E3C3C"
            android:textSize="21sp"
            tools:ignore="HardcodedText,TextFields" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/studentUpdateReport"
            android:layout_width="130sp"
            android:layout_height="30sp"
            android:layout_marginTop="10sp"
            android:gravity="center"
            android:textAlignment="center"
            android:background="@drawable/shape1"
            android:fontFamily="sans-serif-smallcaps"
            android:text="Update Marks"
            android:layout_centerInParent="true"
            android:layout_below="@id/studentNameReport"
            android:textSize="15sp"
            tools:ignore="HardcodedText" />


    </RelativeLayout>

</androidx.cardview.widget.CardView>