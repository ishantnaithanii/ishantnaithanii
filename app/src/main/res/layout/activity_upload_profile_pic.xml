<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="#C5BFBF"
    android:layout_height="match_parent"
    tools:context=".Login_and_Register.UploadProfilePicActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/profilePic_Toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/purple">
        <ImageButton
            android:id="@+id/update_pic_toolbar_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/transparent"
            android:src="@drawable/baseline_arrow_back_24"
            tools:ignore="ContentDescription" />
        <TextView
            android:id="@+id/update_pic_toolbar_textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Update Email"
            android:textColor="@color/white"
            android:textSize="25sp"
            tools:ignore="HardcodedText" />
    </androidx.appcompat.widget.Toolbar>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp"
        android:layout_margin="15dp"
        android:background="@color/white">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/textView_upload_pic_head"
            android:text="Upload your profile pic"
            android:textAlignment="center"
            android:textColor="#00ACC1"
            android:textStyle="bold"
            android:fontFamily="sans-serif-smallcaps"
            android:textAppearance="@style/TextAppearance.AppCompat.Headline"
            tools:ignore="HardcodedText" />

        <androidx.appcompat.widget.AppCompatButton
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/upload_pic_choose_button"
            android:layout_below="@id/textView_upload_pic_head"
            android:layout_marginTop="20sp"
            android:text="Choose Picture"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-smallcaps"
            android:layout_marginRight="70sp"
            android:layout_marginLeft="70sp"
            android:backgroundTint="#15ECD6"
            tools:ignore="HardcodedText,UnusedAttribute" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="500sp"
            android:id="@+id/imageView_profile_dp2"
            android:layout_marginTop="20dp"
            android:background="@drawable/border"
            android:layout_below="@id/upload_pic_choose_button"
            tools:ignore="ContentDescription" />

        <androidx.appcompat.widget.AppCompatButton
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/upload_pic_button"
            android:layout_below="@id/imageView_profile_dp2"
            android:layout_marginTop="10sp"
            android:text="Upload"
            android:textSize="18sp"
            android:fontFamily="sans-serif-smallcaps"
            android:textStyle="bold"
            android:layout_marginLeft="70sp"
            android:layout_marginRight="70sp"
            tools:ignore="HardcodedText" />

        <ProgressBar
            android:id="@+id/profilePic_progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:layout_marginTop="10sp"
            android:visibility="invisible"
            android:layout_gravity="center"/>
    </RelativeLayout>
    </LinearLayout>

</ScrollView>