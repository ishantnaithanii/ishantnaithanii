<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="@color/purple"
    android:orientation="vertical"
    android:layout_height="match_parent"
    tools:context=".Login_and_Register.Login_Register">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_marginTop="10sp"
        android:orientation="horizontal"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/text2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="120sp"
            android:layout_marginTop="20sp"
            android:fontFamily="serif-monospace"
            android:text="EDU APP"
            android:textColor="@color/white"
            android:textSize="50sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />

        <de.hdodenhof.circleimageview.CircleImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginEnd="10sp"
            android:layout_marginStart="10sp"
            android:layout_marginTop="10dp"
            android:src="@drawable/splash" />

    </RelativeLayout>

    <TextView
        android:id="@+id/text1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10sp"
        android:gravity="center"
        android:fontFamily="sans-serif-smallcaps"
        android:text="G. P. SRINAGAR GARHWAL"
        android:textColor="@color/white"
        android:textSize="35sp"
        android:textStyle="bold"

        tools:ignore="HardcodedText" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="12sp"
        android:backgroundTint="@color/white"
        app:cardElevation="10sp"
        android:layout_gravity="center"
        android:layout_marginStart="10sp"
        android:layout_marginEnd="10sp"
        android:layout_height="350dp"
        tools:ignore="UnusedAttribute">
        <ImageView
            android:layout_gravity="center"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/login_register"/>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10sp"
        android:layout_gravity="center"
        android:orientation="horizontal">
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/teacherRegBtn"
        android:layout_width="250dp"
        android:layout_height="55dp"
        android:background="@drawable/shape4"
        android:layout_gravity="center"
        android:layout_marginEnd="10sp"
        android:fontFamily="sans-serif-smallcaps"
        android:text="Teacher Register/Login"
        android:textAllCaps="false"
        android:textSize="22sp"
        tools:ignore="HardcodedText" />
<!--        <androidx.appcompat.widget.AppCompatButton-->
<!--            android:id="@+id/teacherLogBtn"-->
<!--            android:layout_width="180dp"-->
<!--            android:layout_height="55dp"-->
<!--            android:layout_gravity="center"-->
<!--            android:layout_marginStart="10sp"-->
<!--            android:background="@drawable/shape4"-->
<!--            android:fontFamily="sans-serif-smallcaps"-->
<!--            android:text="Teacher Login"-->
<!--            android:textAllCaps="false"-->
<!--            android:textSize="22sp"-->
<!--            tools:ignore="HardcodedText" />-->
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="83dp"
        android:layout_gravity="center"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/studentRegBtn"
            android:layout_width="250dp"
            android:layout_height="55dp"
            android:layout_gravity="center"
            android:layout_marginTop="10sp"
            android:layout_marginEnd="10sp"
            android:background="@drawable/shape4"
            android:fontFamily="sans-serif-smallcaps"
            android:text="Student Register/Login"
            android:textAllCaps="false"
            android:textSize="22sp"
            tools:ignore="HardcodedText" />
        <!--        <androidx.appcompat.widget.AppCompatButton-->
        <!--            android:id="@+id/studentLogBtn"-->
        <!--            android:layout_width="180dp"-->
        <!--            android:layout_height="55dp"-->
        <!--            android:layout_gravity="center"-->
        <!--            android:background="@drawable/shape4"-->
        <!--            android:fontFamily="sans-serif-smallcaps"-->
        <!--            android:text="Teacher Login"-->
        <!--            android:layout_marginTop="10sp"-->
        <!--            android:layout_marginStart="10sp"-->
        <!--            android:textAllCaps="false"-->
        <!--            android:textSize="22sp"-->
        <!--            tools:ignore="HardcodedText" />-->
    </LinearLayout>


</LinearLayout>