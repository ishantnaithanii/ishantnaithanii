<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Login_and_Register.UserProfileActivity"
    android:background="#EDE9E9">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/userprofile_Toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/purple"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:background="#5CC09F"
            tools:ignore="UselessParent">

            <ImageView
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:id="@+id/imageView_profile_dp"
                android:layout_centerInParent="true"
                android:background="@drawable/user2"
                tools:ignore="ContentDescription"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/textView_show_welcome"
                android:layout_below="@id/imageView_profile_dp"
                android:hint="Loading..."
                android:layout_centerHorizontal="true"
                android:layout_marginTop="5dp"
                android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                android:textColor="@color/white"
                tools:ignore="HardcodedText" />

        </RelativeLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="15dp"
            android:layout_margin="15dp"
            android:background="@color/white">
           <!--Show Name-->
            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:id="@+id/ic_profile"
                android:background="@drawable/name"
                tools:ignore="ContentDescription" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/textView_show_full_name"
                android:layout_alignStart="@id/ic_profile"
                android:hint="Loading"
                android:layout_marginStart="50dp"
                android:textSize="18sp"
                tools:ignore="HardcodedText" />
            <View
                android:id="@+id/divider_name"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20sp"
                android:layout_below="@+id/textView_show_full_name"
                android:background="#614B4B"/>

            <!--Show Email-->
            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:id="@+id/ic_email"
                android:background="@drawable/email"
                tools:ignore="ContentDescription"
                android:layout_marginTop="20sp"
                android:layout_below="@id/divider_name"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/textView_show_email"
                android:layout_alignStart="@id/ic_profile"
                android:hint="Loading"
                android:layout_marginTop="20sp"
                android:layout_below="@id/divider_name"
                android:layout_marginStart="50dp"
                android:textSize="18sp"
                tools:ignore="HardcodedText" />
            <View
                android:id="@+id/divider_email"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20sp"
                android:layout_below="@+id/textView_show_email"
                android:background="#614B4B"/>

            <!--Show Mobile-->
            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:id="@+id/ic_mobile"
                android:background="@drawable/telephone"
                tools:ignore="ContentDescription"
                android:layout_marginTop="20sp"
                android:layout_below="@id/divider_email"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/textView_show_mobile"
                android:layout_alignStart="@id/ic_profile"
                android:hint="Loading"
                android:layout_marginTop="20sp"
                android:layout_below="@id/divider_email"
                android:layout_marginStart="50dp"
                android:textSize="18sp"
                tools:ignore="HardcodedText" />
            <View
                android:id="@+id/divider_mobile"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20sp"
                android:layout_below="@+id/textView_show_mobile"
                android:background="#614B4B"/>

            <!--Show Gender-->
            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:id="@+id/ic_gender"
                android:background="@drawable/gender"
                tools:ignore="ContentDescription"
                android:layout_marginTop="20sp"
                android:layout_below="@id/divider_mobile"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/textView_show_gender"
                android:layout_alignStart="@id/ic_profile"
                android:hint="Loading"
                android:layout_marginTop="20sp"
                android:layout_below="@id/divider_mobile"
                android:layout_marginStart="50dp"
                android:textSize="18sp"
                tools:ignore="HardcodedText" />
            <View
                android:id="@+id/divider_gender"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20sp"
                android:layout_below="@+id/textView_show_gender"
                android:background="#614B4B"/>

            <!--Show Branch-->
            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:id="@+id/ic_branch"
                android:background="@drawable/branch2"
                tools:ignore="ContentDescription"
                android:layout_marginTop="20sp"
                android:layout_below="@id/divider_gender"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/textView_show_branch"
                android:layout_alignStart="@id/ic_profile"
                android:hint="Loading"
                android:layout_marginTop="20sp"
                android:layout_below="@id/divider_gender"
                android:layout_marginStart="50dp"
                android:textSize="18sp"
                tools:ignore="HardcodedText" />
            <View
                android:id="@+id/divider_branch"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20sp"
                android:layout_below="@+id/textView_show_branch"
                android:background="#614B4B"/>

            <!--Show DOB-->
            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:id="@+id/ic_dob"
                android:background="@drawable/birthday"
                tools:ignore="ContentDescription"
                android:layout_marginTop="20sp"
                android:layout_below="@id/divider_branch"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/textView_show_dob"
                android:layout_alignStart="@id/ic_profile"
                android:hint="Loading"
                android:layout_marginTop="20sp"
                android:layout_below="@id/divider_branch"
                android:layout_marginStart="50dp"
                android:textSize="18sp"
                tools:ignore="HardcodedText" />

        </RelativeLayout>
        <ProgressBar
            android:id="@+id/userProfile_progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10sp"
            android:visibility="invisible"
            android:layout_gravity="center"/>
    </LinearLayout>


</ScrollView>